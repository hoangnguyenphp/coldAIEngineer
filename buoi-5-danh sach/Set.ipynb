   "source": [
    "# collection of the unique elements and no order\n",
    "\n",
    "a = {1, 3 ,3, 5}\n",
    "print(a)\n",
    "\n",
    "# conver list to set\n",
    "a = [1, 3 ,3, 5]\n",
    "print(set(a))\n",
    "\n",
    "a = {1, 2, 3, 4, 5}\n",
    "b = {4, 5, 6, 7, 8}\n",
    "\n",
    "# union\n",
    "print (a.union(b))\n",
    "\n",
    "# intersection\n",
    "print(a.intersection(b))\n",
    "\n",
    "# diffirence\n",
    "print(a.difference(b))"
   ]
  }
