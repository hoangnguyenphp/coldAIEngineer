   "source": [
    "import random as rd\n",
    "\n",
    "numbers = rd.sample(range(100), 10)\n",
    "print(type(numbers), numbers)\n",
    "\n",
    "# find max\n",
    "maxNum = numbers[0]\n",
    "for n in numbers:\n",
    "    if maxNum < n:\n",
    "        maxNum = n\n",
    "\n",
    "print(maxNum)\n",
    "# built in function\n",
    "print(min(numbers))\n",
    "print(max(numbers))\n",
    "\n"
   ]
  }
